{
  "expo": {
    "name": "EasyTV",
    "slug": "easytv",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "https://raw.githubusercontent.com/Gokalpon/EasyTV/main/EasyTVLogo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "https://raw.githubusercontent.com/Gokalpon/EasyTV/main/EasyTVLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.easytv.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "https://raw.githubusercontent.com/Gokalpon/EasyTV/main/EasyTVLogo.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.easytv.app"
    },
    "web": {
      "favicon": "https://raw.githubusercontent.com/Gokalpon/EasyTV/main/EasyTVLogo.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "13.0"
          }
        }
      ]
    ]
  }
}
