{
  "appId": "com.easytv.app",
  "appName": "EasyTV",
  "webDir": "www",
  "server": {
    "allowNavigation": ["*"]
  },
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "backgroundColor": "#0a0a0a",
    "preferredContentMode": "mobile",
    "scheme": "capacitor"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0a0a0a"
    },
    "Keyboard": {
      "resize": "none",
      "style": "DARK"
    }
  }
}
